<!-- Settings Page -->
<div v-show="page === 'settings'" class="w-full max-w-4xl pb-12">
<div class="flex items-center justify-between mb-8">
<div>
<h2 class="text-2xl font-bold tracking-tight text-foreground">Settings</h2>
<p class="text-muted font-medium text-sm mt-1">Dashboard configuration and service paths</p>
</div>
</div>

<div class="stat-card overflow-hidden relative">
<div class="absolute top-0 left-0 w-full h-1 bg-primary/40"></div>
<div class="p-6 border-b border-border/50 bg-black/5 dark:bg-white/5">
<h3 class="form-label !mb-0 font-bold">Application configuration</h3>
</div>

<div class="p-8 space-y-10 bg-background">
<div class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-10">

<div class="w-full">
<label class="form-label">Dashboard Port</label>
<input v-model.number="settings.dashboardPort" type="number" class="form-input" placeholder="6443" />
<p class="text-[11px] text-muted mt-2 font-bold tracking-wide uppercase opacity-70">Restart dashboard after changing</p>
</div>

<div class="w-full">
<label class="form-label">ACME Email (Let's Encrypt)</label>
<input v-model="settings.acmeEmail" type="email" class="form-input" placeholder="admin@example.com" />
<p class="text-[11px] text-muted mt-2 font-bold tracking-wide uppercase opacity-70">Required for certificate issuance</p>
</div>

<div class="w-full">
<label class="form-label">Nginx Directory</label>
<input v-model="settings.nginxDir" class="form-input font-mono text-[13px]" placeholder="/etc/nginx" />
<p class="text-[11px] text-muted mt-2 font-bold tracking-wide uppercase opacity-70">Where nginx.conf is located</p>
</div>

<div class="w-full">
<label class="form-label">SSL Settings Directory</label>
<input v-model="settings.sslDir" class="form-input font-mono text-[13px]" placeholder="/etc/nginx/ssl" />
<p class="text-[11px] text-muted mt-2 font-bold tracking-wide uppercase opacity-70">Directory for default SSL certs</p>
</div>

</div>

<div class="border-t border-border/50 pt-10">
<div class="w-full max-w-md">
<label class="form-label">New Password</label>
<input v-model="settings.password" type="password" class="form-input" placeholder="Leave blank to keep current" />
</div>
</div>

</div>

<!-- Actions area -->
<div class="p-5 border-t border-border bg-black/5 dark:bg-white/5 flex flex-col sm:flex-row sm:items-center justify-between gap-4">
<div class="flex items-center gap-3">
<button @click="saveSettings" :disabled="settings.loading" class="btn btn-primary min-w-[140px] shadow-sm">
<svg v-if="settings.loading" class="w-4 h-4 animate-spin -ml-1 mr-2 inline-block" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path></svg>
{{ settings.loading ? 'Saving...' : 'Save Settings' }}
</button>
</div>
<div>
<span v-if="settings.msg" class="text-green-500 text-[13px] font-bold px-3 py-1.5 rounded-[10px] bg-green-500/10 border border-green-500/20">{{ settings.msg }}</span>
<span v-if="settings.error" class="text-red-500 text-[13px] font-bold px-3 py-1.5 rounded-[10px] bg-red-500/10 border border-red-500/20">{{ settings.error }}</span>
</div>
</div>
</div>

<!-- Linux Permissions card (hidden on Windows) -->
<div v-if="settings.platform !== 'win32'" class="stat-card overflow-hidden relative mt-6">
  <div class="absolute top-0 left-0 w-full h-1" :class="permissions.configured ? 'bg-green-500/40' : 'bg-yellow-500/40'"></div>
  <div class="p-6 border-b border-border/50 bg-black/5 dark:bg-white/5 flex items-center justify-between">
    <div>
      <h3 class="form-label !mb-0 font-bold">Linux Permissions</h3>
      <p class="text-[11px] text-muted mt-1 font-bold tracking-wide uppercase opacity-70">Passwordless sudo for nginx and systemctl</p>
    </div>
    <span v-if="permissions.configured" class="text-green-500 text-xs font-bold px-2.5 py-1 rounded-lg bg-green-500/10 border border-green-500/20">✓ Configured</span>
    <span v-else class="text-yellow-500 text-xs font-bold px-2.5 py-1 rounded-lg bg-yellow-500/10 border border-yellow-500/20">⚠ Required</span>
  </div>
  <div class="p-8 bg-background">
    <p v-if="permissions.configured" class="text-sm text-muted">Passwordless sudo is configured. The dashboard can manage nginx and systemctl without prompting for a password.</p>
    <div v-else>
      <p class="text-sm text-muted mb-6">The dashboard needs passwordless sudo to control nginx and systemctl. Enter your sudo password once to configure it.</p>
      <div class="w-full max-w-md">
        <label class="form-label">Sudo Password</label>
        <input v-model="permissions.password" type="password" class="form-input" placeholder="Enter your sudo password" @keyup.enter="setupPermissions" />
      </div>
    </div>
  </div>
  <div v-if="!permissions.configured" class="p-5 border-t border-border bg-black/5 dark:bg-white/5 flex flex-col sm:flex-row sm:items-center justify-between gap-4">
    <button @click="setupPermissions" :disabled="permissions.loading || !permissions.password" class="btn btn-primary min-w-[180px] shadow-sm">
      <svg v-if="permissions.loading" class="w-4 h-4 animate-spin -ml-1 mr-2 inline-block" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path></svg>
      {{ permissions.loading ? 'Setting up...' : 'Setup Permissions' }}
    </button>
    <div>
      <span v-if="permissions.msg" class="text-green-500 text-[13px] font-bold px-3 py-1.5 rounded-[10px] bg-green-500/10 border border-green-500/20">{{ permissions.msg }}</span>
      <span v-if="permissions.error" class="text-red-500 text-[13px] font-bold px-3 py-1.5 rounded-[10px] bg-red-500/10 border border-red-500/20">{{ permissions.error }}</span>
    </div>
  </div>
</div>
</div>
